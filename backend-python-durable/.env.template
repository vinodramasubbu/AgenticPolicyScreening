FUNCTIONS_WORKER_RUNTIME=python
AzureWebJobsStorage=UseDevelopmentStorage=true
DURABLE_TASK_SCHEDULER_CONNECTION_STRING=Endpoint=http://localhost:8080;Authentication=None
TASKHUB_NAME=insurance-screening

# Microsoft Foundry Project configuration for agent-based screening
# Get these values from your Azure Foundry project
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry-project>.api.aml.ms/models/v1
FOUNDRY_MODEL_DEPLOYMENT_NAME=<your-model-deployment-name>

# Cosmos DB output persistence for final decisions
COSMOS_ENDPOINT=https://aifoundryestcbd1.documents.azure.com:443/
COSMOS_DATABASE_NAME=policydb
COSMOS_CONTAINER_NAME=decision
# Optional: set COSMOS_KEY for local key-based auth. If empty, managed identity is used.
COSMOS_KEY=
